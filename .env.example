# Copy this file to .env and fill in real values.
# This project uses Next.js, which loads .env automatically.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_RECONCILE_SECRET=your-reconcile-secret

# Resend (Transactional Email)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional (recommended): used to sign the restore-access cookie
# RESTORE_TOKEN_SECRET=your-long-random-string

